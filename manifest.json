{
  "manifest_version": 3,
  "name": "360",
  "short_name": "360",
  "version": "1.1.0",
  "description": "360 as your default search engine and new tab page — AI, weather, translator and more.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "360-search.com/newtab.html"
  },
  "omnibox": {
    "keyword": "360"
  },
  "permissions": [
    "search"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "360"
  }
}
